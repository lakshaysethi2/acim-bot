# ACIM Bot — Environment Variables
# Copy this file to .env and fill in the values.

# ── General ──────────────────────────────────────────────
# Which platform to run: "discord" or "telegram" (no other values accepted)
BOT_MODE=discord

# Health-check HTTP port (used by Docker HEALTHCHECK)
HEALTH_PORT=8080

# Maximum number of search results returned by /acim search (1-25)
ACIM_SEARCH_MAX_RESULTS=3

# ── Discord ──────────────────────────────────────────────
# Required when BOT_MODE=discord
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: restrict slash-command sync to a specific guild (faster during dev)
# DISCORD_GUILD_ID=123456789012345678

# Whether to sync application commands on startup (default: true).
# Set to false in production to avoid rate-limiting on restarts.
DISCORD_SYNC_COMMANDS=true

# ── Telegram ─────────────────────────────────────────────
# Required when BOT_MODE=telegram
# Create a bot via @BotFather on Telegram
TELEGRAM_TOKEN=
